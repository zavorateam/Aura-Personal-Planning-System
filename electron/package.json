{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "description": "A local-first, encrypted personal management system with AI-driven workload analysis and Git-based synchronization.",
  "author": "zavorateam",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev:renderer": "vite --port=3000 --host=0.0.0.0",
    "dev:electron": "electron .",
    "dev": "npm run dev:renderer",
    "build:renderer": "vite build",
    "build:app": "npm run build:renderer && electron-builder",
    "build:win-portable": "npm run build:renderer && electron-builder --win portable",
    "build:linux-appimage": "npm run build:renderer && electron-builder --linux AppImage",
    "dist": "npm run build:app",
    "start": "electron .",
    "preview": "vite preview",
    "clean": "rm -rf dist build",
    "gen:icons": "node scripts/generate-icons.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "octokit": "^5.0.5",
    "otplib": "^13.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "vite": "^6.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^30.0.0",
    "electron-builder": "^24.8.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.aura.personal.os",
    "productName": "Aura Personal OS",
    "directories": {
      "output": "build",
      "buildResources": "res"
    },
    "icon": "res/icon",
    "files": [
      "dist/**",
      "main.js",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
